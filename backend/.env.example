# ── Uygulama ───────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_GLOBAL_PREFIX=api
APP_CORS_ORIGIN=*

# ── Veritabanı (PostgreSQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=stocktrack
DB_PASSWORD=stocktrack
DB_NAME=stocktrack
# Üretimde 'false' tutun; şema değişikliklerini migration ile yönetin.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ── JWT / Kimlik Doğrulama ─────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── İş Kuralı Varsayılanları ───────────────────────────────
DEFAULT_CURRENCY=TRY
DEFAULT_RATE_PER_M2=75.00
DEFAULT_WAREHOUSE_CODE=MERKEZ

# ── İşletme / Belge Kimliği (PDF fatura/irsaliye/teklif) ───
BUSINESS_NAME=StockTrack Reklam & İmalat
BUSINESS_ADDRESS=
BUSINESS_PHONE=
BUSINESS_TAX_NO=
# Logoyu PDF başlığına basmak için mutlak/erişilebilir dosya yolu (opsiyonel).
BUSINESS_LOGO_PATH=
# Müşteri portalı linklerinin temel adresi (token sonuna eklenir).
PORTAL_BASE_URL=http://localhost:5173/portal

# ── Döviz (multi-currency) ─────────────────────────────────
EXCHANGE_RATE_BASE=TRY
# Harici kur API'si (boşsa otomatik senkron kapalı). Beklenen yanıt:
# { "base": "TRY", "rates": { "USD": 0.031, "EUR": 0.029 } }
EXCHANGE_RATE_API_URL=
EXCHANGE_RATE_SYNC_CRON=0 6 * * *

# ── Zamanlayıcı (cluster'da yalnızca BİR replikada true) ───
SCHEDULER_ENABLED=true

# ── Veritabanı yedekleme ───────────────────────────────────
# Diske alınan otomatik yedekler (pg_dump). Dizin + zamanlama + saklama.
BACKUP_DIR=backups
BACKUP_CRON=0 3 * * *
# pg_dump/psql PATH'te değilse ikili dizinini verin (örn. C:\Program Files\PostgreSQL\16\bin).
BACKUP_PG_BIN_DIR=
BACKUP_KEEP=14
# Şifreli yedeğin Telegram'a otomatik gönderimi (varsayılan: saatlik).
BACKUP_TELEGRAM_CRON=0 * * * *
# Yedeğin gönderileceği Telegram sohbet kimliği (boşsa TELEGRAM_OWNER_CHAT_ID kullanılır).
BACKUP_TELEGRAM_CHAT_ID=
# Yedek anahtar dosyaları. Public = şifreleme (API'da tutulur), private = şifre
# çözme (web arayüzünde gösterilir). Dosyalar yoksa ilk çalıştırmada üretilir.
BACKUP_PUBLIC_KEY_FILE=backups/backup-key.pub.pem
BACKUP_PRIVATE_KEY_FILE=backups/backup-key.priv.pem
# Günlük Telegram yedek mesajının kalıcı durumu (mesaj id, gün, döküm).
BACKUP_TELEGRAM_STATE_FILE=backups/telegram-backup-state.json

# ── Bildirim (Uygulama içi/Log + Telegram + WhatsApp) ──────
# TELEGRAM_BOT_TOKEN boşsa yalnızca Log kanalı çalışır.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
DEBT_REMINDER_CRON=0 9 * * *
DEBT_REMINDER_THRESHOLD=0
# WhatsApp (Meta Cloud API). Boşsa kanal pasif (Log + Telegram çalışmaya devam eder).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# ── İlk Kurulum Tohumlaması ────────────────────────────────
# OWNER + varsayılanlar API açılışında otomatik (idempotent) oluşturulur.
# Kapatmak için false yapın (örn. migration tabanlı kuruluma geçerken).
SEED_ON_BOOT=true
SEED_OWNER_EMAIL=owner@stocktrack.local
SEED_OWNER_PASSWORD=Owner123!

# ── (Opsiyonel) Redis — cluster'da paylaşılan durum için ───
# REDIS_HOST=localhost
# REDIS_PORT=6379
